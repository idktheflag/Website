---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = await getCollection('blog');

const ctfs = [
    {
        name: 'UMassCTF 2026',
        place: 176,
        ctfPoints: 1800,
        ratingPoints: 24.766,
        writeups: [],
    },
    {
        name: 'SillyCTF 2',
        place: 23,
        ctfPoints: 4720,
        ratingPoints: 13.486,
        writeups: [],
    },
    {
        name: 'RITSEC CTF 2026',
        place: 75,
        ctfPoints: 1511,
        ratingPoints: 12.004,
        writeups: [],
        note: '7th Academic Division',
    },
    {
        name: 'Lockheed CyberQuest',
        place: '1st & 2nd',
        ctfPoints: '5230 / 5050',
        ratingPoints: null,
        writeups: [],
        note: 'riverxia 1st (full solve), nila 2nd',
    },
    {
        name: 'MetaCTF March 2026 Flash CTF',
        place: '12th & 13th (full solve)',
        ctfPoints: 1050,
        ratingPoints: null,
        writeups: ['whiterabbit-writeup', 'brandkit-studio-writeup'],
        note: 'Individual',
    },
    {
        name: 'picoCTF 2026',
        place: '14th HS / 35th Global (full solve)',
        ctfPoints: 14500,
        ratingPoints: null,
        writeups: ['paper-2-writeup'],
        note: 'Not on CTFtime',
    },
    {
        name: '0xFUN CTF 2026',
        place: 72,
        ctfPoints: 7291,
        ratingPoints: 7.088,
        writeups: [],
    },
    {
        name: 'LA CTF 2026',
        place: 150,
        ctfPoints: 2871,
        ratingPoints: 19.276,
        writeups: [],
    },
    {
        name: 'Pragyan CTF 2026',
        place: 335,
        ctfPoints: 450,
        ratingPoints: 0.128,
        writeups: [],
    },
    {
        name: 'PascalCTF 2026',
        place: 134,
        ctfPoints: 4705,
        ratingPoints: 15.394,
        writeups: [],
    },
];

// Resolve writeup posts
function getWriteupPosts(writeupIds: string[]) {
    return writeupIds
        .map(id => posts.find(p => p.id === id))
        .filter(Boolean);
}
---

<Layout title="CTFs | idktheflag">
    <main class="container">
        <h1>CTF History</h1>
        <div class="stats-bar">
            <div class="stat">
                <span class="stat-label">Overall Rating</span>
                <span class="stat-value">#370</span>
            </div>
            <div class="stat">
                <span class="stat-label">Country (US)</span>
                <span class="stat-value">#36</span>
            </div>
            <div class="stat">
                <span class="stat-label">Rating Points</span>
                <span class="stat-value">95.883</span>
            </div>
            <div class="stat">
                <span class="stat-label">Year</span>
                <span class="stat-value">2026</span>
            </div>
        </div>
        <p class="ctftime-link">
            full stats on <a href="https://ctftime.org/team/419270" target="_blank">CTFtime</a>
        </p>

        <div class="ctf-table-wrapper">
            <table class="ctf-table">
                <thead>
                    <tr>
                        <th>Place</th>
                        <th>Event</th>
                        <th>CTF Points</th>
                        <th>Rating Points</th>
                        <th>Writeups</th>
                    </tr>
                </thead>
                <tbody>
                    {ctfs.map(ctf => {
                        const writeupPosts = getWriteupPosts(ctf.writeups);
                        return (
                            <tr>
                                <td class="place" data-label="Place: ">{typeof ctf.place === 'number' ? `#${ctf.place}` : ctf.place}</td>
                                <td class="event" data-label="">{ctf.name}{ctf.note && <span class="note"> ({ctf.note})</span>}</td>
                                <td data-label="CTF Points: ">{ctf.ctfPoints !== null ? ctf.ctfPoints.toLocaleString() : <span class="no-writeup">-</span>}</td>
                                <td data-label="Rating: ">{ctf.ratingPoints !== null ? ctf.ratingPoints : <span class="no-writeup">-</span>}</td>
                                <td class={`writeups-cell ${writeupPosts.length === 0 ? 'empty' : ''}`} data-label="Writeups: ">
                                    {writeupPosts.length > 0 ? (
                                        writeupPosts.map(p => (
                                            <a href={`/blog/${p!.id}/`}>{p!.data.title}</a>
                                        ))
                                    ) : (
                                        <span class="no-writeup">-</span>
                                    )}
                                </td>
                            </tr>
                        );
                    })}
                </tbody>
            </table>
        </div>
    </main>
</Layout>

<style>
    .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .stats-bar {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin: 1.5rem 0;
        padding: 1rem 1.5rem;
        background-color: #161b22;
        border: 1px solid #30363d;
        border-left: 4px solid var(--accent);
        border-radius: 4px;
    }

    .stat {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .stat-label {
        font-size: 0.8em;
        color: #8b949e;
        font-family: monospace;
        text-transform: uppercase;
    }

    .stat-value {
        font-size: 1.3em;
        font-weight: bold;
        color: var(--accent);
        font-family: monospace;
    }

    .ctftime-link {
        color: #8b949e;
        margin-bottom: 2rem;
    }

    .ctf-table-wrapper {
        overflow-x: auto;
    }

    .ctf-table {
        width: 100%;
        border-collapse: collapse;
        font-family: monospace;
        font-size: 0.95em;
    }

    .ctf-table th {
        text-align: left;
        padding: 0.6rem 0.8rem;
        border-bottom: 2px solid var(--accent);
        color: var(--accent);
        font-size: 0.85em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .ctf-table td {
        padding: 0.6rem 0.8rem;
        border-bottom: 1px solid #21262d;
        white-space: nowrap;
    }

    .ctf-table tr:hover td {
        background-color: #161b22;
    }

    .place {
        color: var(--accent);
        font-weight: bold;
        white-space: nowrap;
    }

    .event {
        font-weight: bold;
        color: var(--text-heading);
        white-space: nowrap;
    }

    .writeups-cell {
        white-space: normal;
    }

    .writeups-cell a {
        display: block;
        font-size: 0.9em;
    }

    .no-writeup {
        color: #484f58;
    }

    .note {
        color: #8b949e;
        font-size: 0.85em;
        font-weight: normal;
    }

    @media (max-width: 720px) {
        .stats-bar {
            gap: 1rem;
        }

        .stat-value {
            font-size: 1.1em;
        }

        .ctf-table thead {
            display: none;
        }

        .ctf-table,
        .ctf-table tbody,
        .ctf-table tr,
        .ctf-table td {
            display: block;
        }

        .ctf-table tr {
            padding: 0.8rem 0;
            border-bottom: 1px solid #21262d;
        }

        .ctf-table td {
            padding: 0.15rem 0;
            border: none;
        }

        .ctf-table td::before {
            content: attr(data-label);
            font-size: 0.8em;
            color: #8b949e;
        }

        .event {
            font-size: 1.05em;
            margin-bottom: 0.15rem;
            order: -1;
        }

        .writeups-cell.empty {
            display: none;
        }

        .no-writeup {
            display: none;
        }
    }
</style>
