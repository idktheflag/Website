---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
    const posts = await getCollection('blog');
    return posts.map(post => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const teamMembers = await getCollection('team');
const pfpMap = Object.fromEntries(teamMembers.map(m => [m.id, m.data.pfp]));

const authorIds = Array.isArray(post.data.author) ? post.data.author : [post.data.author];
const authors = authorIds.map(id => ({
    id,
    pfp: pfpMap[id] ?? null,
}));
---

<Layout title={`${post.data.title} | idktheflag`}>
    <article class="writeup">
        <header>
            <h1>{post.data.title}</h1>
            <div class="meta">
                <div class="meta-authors">
                    <span>{authors.length > 1 ? 'Authors:' : 'Author:'}</span>
                    {authors.map(({ id, pfp }) => (
                        <div class="author">
                            {pfp && <img src={pfp} alt={id} class="author-pfp" />}
                            <a href={`/team/${id}`}>{id}</a>
                        </div>
                    ))}
                </div>
                <div class="meta-date">
                    <span>> DATE: {post.data.pubDate.toLocaleDateString()}</span>
                </div>
            </div>
            <p class="desc">{post.data.description}</p>
        </header>
        
        <div class="markdown-content">
            <Content />
        </div>
    </article>
</Layout>

<style>
    .writeup {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    header {
        border-bottom: 1px solid #30363d;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
    }

    .meta {
        font-family: monospace;
        font-size: 1.1em;
        margin-top: 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .meta-authors {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        color: var(--accent);
    }

    .meta-authors a {
        color: var(--accent);
        text-decoration: none;
    }

    .meta-authors a:hover {
        text-decoration: underline;
    }

    .author {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .author-pfp {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        object-fit: cover;
    }

    .meta-date {
        color: var(--accent);
    }

    .desc {
        font-style: italic;
        color: #8b949e;
    }

    /* Target the injected Markdown elements */
    .markdown-content :global(h2) {
        color: var(--accent-hover);
        margin-top: 1.5em;
    }

    .markdown-content :global(pre) {
        background-color: #161b22;
        padding: 1rem;
        border-radius: 6px;
        border: 1px solid #30363d;
        overflow-x: auto;
    }

    .markdown-content :global(code) {
        font-family: "Courier New", monospace;
        background-color: #161b22;
        padding: 0.2em 0.4em;
        border-radius: 3px;
        color: #e6edf3;
    }

    .markdown-content :global(pre code) {
        background-color: transparent;
        padding: 0;
        border: none;
    }

    .markdown-content :global(table) {
        width: 100%;
        overflow-x: auto;
        display: block;
    }

    @media (max-width: 720px) {
        .writeup {
            padding: 1.5rem 0.8rem;
        }

        .markdown-content :global(pre) {
            font-size: 0.85em;
            padding: 0.7rem;
        }
    }
</style>
