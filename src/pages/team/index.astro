---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const members = await getCollection('team');
const active = members.filter(m => m.data.active).sort((a, b) => a.data.order - b.data.order);
const retired = members.filter(m => !m.data.active).sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Bios | idktheflag">
    <main class="container">
        <section class="content">
            <h1>> team bios</h1>
            <p class="subtitle">click a member to see their full profile</p>

            <h2>Active</h2>
            <div class="member-grid">
                {active.map(m => (
                    <a href={`/team/${m.id}`} class="member-card">
                        <img src={m.data.pfp} alt={m.data.name} class="member-pfp" />
                        <div class="member-info">
                            <strong>{m.data.name}</strong>
                            <span class="member-role">{m.data.role}</span>
                            {m.data.specialties.length > 0 && (
                                <span class="member-specs">{m.data.specialties.join(', ')}</span>
                            )}
                        </div>
                    </a>
                ))}
            </div>

            {retired.length > 0 && (
                <>
                    <h2>Retired/Semi-Active</h2>
                    <div class="member-grid">
                        {retired.map(m => (
                            <a href={`/team/${m.id}`} class="member-card retired">
                                <img src={m.data.pfp} alt={m.data.name} class="member-pfp" />
                                <div class="member-info">
                                    <strong>{m.data.name}</strong>
                                    <span class="member-role">{m.data.role}</span>
                                </div>
                            </a>
                        ))}
                    </div>
                </>
            )}
        </section>
    </main>
</Layout>

<style>
    .container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    h1 {
        font-family: monospace;
        color: var(--accent);
    }

    .subtitle {
        color: #8b949e;
        font-style: italic;
        margin-top: -0.5rem;
        margin-bottom: 2rem;
    }

    h2 {
        color: var(--text-heading);
        margin-top: 2rem;
        margin-bottom: 1rem;
    }

    .member-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1rem;
    }

    .member-card {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 0.8rem;
        border: 1px solid #30363d;
        border-radius: 6px;
        text-decoration: none;
        color: var(--text-color);
        transition: border-color 0.2s ease;
    }

    .member-card:hover {
        border-color: var(--accent);
    }

    .member-card.retired {
        opacity: 0.6;
    }

    .member-pfp {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .member-info {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
    }

    .member-role {
        font-family: monospace;
        font-size: 0.8em;
        color: var(--accent);
    }

    .member-specs {
        font-size: 0.8em;
        color: #8b949e;
    }
</style>
