</Layout>

<style>
    .section-note {
        color: #8b949e;
        font-style: italic;
        font-size: 0.9em;
        margin-top: -0.5rem;
        margin-bottom: 0.5rem;
    }

    .container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .terminal-box {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-left: 4px solid var(--accent);
        padding: 1.5rem;
        margin: 2rem 0;
        font-family: "Courier New", monospace;
        border-radius: 4px;
    }

    .terminal-box p {
        margin: 0.5rem 0;
        color: #e6edf3;
    }

    .prompt {
        color: var(--accent);
        font-weight: bold;
    }

    .prose p {
        margin-bottom: 1.5rem;
        font-size: 1.1em;
    }

    .prose h2 {
        margin-top: 2rem;
        color: var(--text-heading);
    }

    .roster-list {
        list-style-type: square;
        padding-left: 1.5rem;
    }

    .roster-list li {
        margin-bottom: 0.8rem;
        font-size: 1.1em;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .contact-list {
        list-style-type: square;
        padding-left: 1.5rem;
    }

    .contact-list li {
        margin-bottom: 0.8rem;
        font-size: 1.1em;
    }

    .roster-pfp {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    @media (max-width: 720px) {
        .contact-list li {
            font-size: 0.85em;
            word-break: break-word;
        }

        .roster-list li {
            font-size: 0.9em;
            flex-wrap: nowrap;
        }

        .roster-pfp {
            width: 28px;
            height: 28px;
        }

        .prose p {
            font-size: 1em;
        }
    }
</style>
