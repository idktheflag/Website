---
import { getCollection } from 'astro:content';

const teamMembers = await getCollection('team');
const blogPosts = await getCollection('blog');

const teamData = teamMembers.map(m => ({
    id: m.id,
    name: m.data.name,
    role: m.data.role,
    specialties: m.data.specialties,
    status: m.data.status,
}));

const blogData = blogPosts.map(p => ({
    id: p.id,
    title: p.data.title,
    date: p.data.pubDate.toLocaleDateString(),
    author: p.data.author,
}));
---

<div id="terminal-overlay" class="terminal-hidden">
    <div id="terminal-window">
        <div id="terminal-titlebar">
            <div class="terminal-title-dots">
                <span class="dot dot-red"></span>
                <span class="dot dot-yellow"></span>
                <span class="dot dot-green"></span>
            </div>
            <span class="terminal-title-text">hacker@idktheflag:~</span>
            <button id="terminal-close" aria-label="Close terminal">&times;</button>
        </div>
        <div id="terminal-body">
            <div id="terminal-output"></div>
            <div id="terminal-input-line">
                <span id="terminal-prompt">hacker@idktheflag:~$&nbsp;</span>
                <input id="terminal-input" type="text" autofocus spellcheck="false" autocomplete="off" />
            </div>
        </div>
    </div>
</div>

<script define:vars={{ teamData, blogData }}>
(function() {
    // Virtual filesystem
    const fs = {
        '/': {
            type: 'dir',
            children: ['home', 'blog', 'team', 'ctfs', 'about'],
        },
        '/home': {
            type: 'dir',
            children: [],
            desc: 'home sweet home',
        },
        '/blog': {
            type: 'dir',
            children: blogData.map(p => p.id + '.md'),
            desc: 'writeups and ramblings',
        },
        '/team': {
            type: 'dir',
            children: teamData.map(m => m.id),
            desc: 'team member bios',
        },
        '/ctfs': {
            type: 'dir',
            children: ['results.txt'],
            desc: 'ctf competition history',
        },
        '/about': {
            type: 'dir',
            children: ['README.md'],
            desc: 'about idktheflag',
        },
        '/about/README.md': {
            type: 'file',
            content: [
                '# idktheflag',
                '',
                '[STATUS]: Active (very)',
                '[SPECIALTY]: depends on who on the team ur referring to',
                '[MOTTO]: "i forgor what the flag is"',
                '',
                'we are <weak>idktheflag</weak>',
                'ms paint logo go brrr',
                'caffeine addict team',
                '',
                'CTFtime: https://ctftime.org/team/419270',
            ].join('\n'),
        },
        '/ctfs/results.txt': {
            type: 'file',
            content: [
                '=== idktheflag CTF Results (2026) ===',
                '',
                'Overall Rating: #576 (41.885 pts)',
                'Country (US): #44',
                '',
                'Place            | Event              | CTF Pts  | Rating Pts',
                '-----------------|--------------------|---------|-----------',
                '14th HS/35th Glb | picoCTF 2026       | 14,500   | -  (not on CTFtime)',
                '#72              | 0xFUN CTF 2026     | 7,291    | 7.088',
                '#134             | PascalCTF 2026     | 4,705    | 15.394',
                '#150             | LA CTF 2026        | 2,871    | 19.276',
                '#335             | Pragyan CTF 2026   | 450      | 0.128',
            ].join('\n'),
        },
    };

    // Add blog post files
    blogData.forEach(p => {
        const authors = Array.isArray(p.author) ? p.author.join(', ') : p.author;
        fs['/blog/' + p.id + '.md'] = {
            type: 'file',
            content: `# ${p.title}\nDate: ${p.date}\nAuthor: ${authors}\n\nView full writeup: /blog/${p.id}/`,
        };
    });

    // Add team member files
    teamData.forEach(m => {
        fs['/team/' + m.id] = {
            type: 'file',
            content: [
                `# ${m.name}`,
                `Role: ${m.role}`,
                `Status: ${m.status}`,
                m.specialties.length > 0 ? `Specialties: ${m.specialties.join(', ')}` : '',
                '',
                `View full bio: /team/${m.id}/`,
            ].filter(Boolean).join('\n'),
        };
    });

    let cwd = '/';
    let history = [];
    let historyIndex = -1;

    const commands = {
        help: {
            desc: 'Show available commands. Usage: help [command]',
            fn: (args) => {
                if (args[0]) {
                    const cmd = commands[args[0]];
                    if (!cmd) return `help: unknown command '${args[0]}'`;
                    return `${args[0]} - ${cmd.desc}`;
                }
                return [
                    'Available commands:',
                    '',
                    '  ls [path]        List directory contents',
                    '  cd <path>        Change directory',
                    '  cat <file>       Display file contents',
                    '  pwd              Print working directory',
                    '  clear            Clear the terminal',
                    '  open [path]      Open page in browser',
                    '  whoami           Display current user',
                    '  team             List team members',
                    '  ctfs             Show CTF results',
                    '  blog             List blog posts',
                    '  neofetch         System info',
                    '  man <command>    Manual for a command (alias: help)',
                    '  exit             Close terminal',
                    '',
                    'Type "help <command>" for details on a specific command.',
                    'Use Tab for auto-completion. Use Up/Down for command history.',
                ].join('\n');
            },
        },
        man: {
            desc: 'Manual pages. Usage: man <command>',
            fn: (args) => commands.help.fn(args),
        },
        ls: {
            desc: 'List directory contents. Usage: ls [path]',
            fn: (args) => {
                const target = resolvePath(args[0] || '.');
                const node = fs[target];
                if (!node) return `ls: cannot access '${args[0]}': No such file or directory`;
                if (node.type === 'file') return target.split('/').pop();
                return node.children.map(c => {
                    const full = target === '/' ? '/' + c : target + '/' + c;
                    const child = fs[full];
                    if (child && child.type === 'dir') return c + '/';
                    return c;
                }).join('  ');
            },
        },
        cd: {
            desc: 'Change directory. Usage: cd <path>',
            fn: (args) => {
                if (!args[0] || args[0] === '~') { cwd = '/'; updatePrompt(); return ''; }
                const target = resolvePath(args[0]);
                const node = fs[target];
                if (!node) return `cd: ${args[0]}: No such file or directory`;
                if (node.type !== 'dir') return `cd: ${args[0]}: Not a directory`;
                cwd = target;
                updatePrompt();
                return '';
            },
        },
        pwd: {
            desc: 'Print working directory',
            fn: () => cwd,
        },
        cat: {
            desc: 'Display file contents. Usage: cat <file>',
            fn: (args) => {
                if (!args[0]) return 'cat: missing operand';
                const target = resolvePath(args[0]);
                const node = fs[target];
                if (!node) return `cat: ${args[0]}: No such file or directory`;
                if (node.type === 'dir') return `cat: ${args[0]}: Is a directory`;
                return node.content;
            },
        },
        clear: {
            desc: 'Clear the terminal screen',
            fn: () => { document.getElementById('terminal-output').innerHTML = ''; return ''; },
        },
        whoami: {
            desc: 'Display current user',
            fn: () => 'hacker (guest) @ idktheflag.sh',
        },
        open: {
            desc: 'Open a page in the browser. Usage: open [path]',
            fn: (args) => {
                const page = args[0] || cwd;
                let url;
                if (page === '/' || page === '/home') url = '/';
                else if (page.startsWith('http')) url = page;
                else url = page.replace(/\.md$/, '/');
                window.location.href = url;
                return `Opening ${url}...`;
            },
        },
        team: {
            desc: 'List all team members',
            fn: () => {
                const active = teamData.filter(m => m.status === 'active');
                const semi = teamData.filter(m => m.status === 'semi-active');
                const retired = teamData.filter(m => m.status === 'retired');
                let out = ['=== Active ==='];
                active.forEach(m => out.push(`  ${m.name.padEnd(16)} ${m.role.padEnd(20)} [${m.specialties.join(', ')}]`));
                if (semi.length) {
                    out.push('', '=== Semi-Active ===');
                    semi.forEach(m => out.push(`  ${m.name.padEnd(16)} ${m.role.padEnd(20)} [${m.specialties.join(', ')}]`));
                }
                if (retired.length) {
                    out.push('', '=== Retired ===');
                    retired.forEach(m => out.push(`  ${m.name.padEnd(16)} ${m.role}`));
                }
                out.push('', 'Use "cat /team/<name>" for details, or "open /team/<name>" to visit their bio.');
                return out.join('\n');
            },
        },
        blog: {
            desc: 'List blog posts',
            fn: () => {
                if (blogData.length === 0) return 'No blog posts yet.';
                let out = ['=== Blog Posts ===', ''];
                blogData.forEach(p => {
                    out.push(`  [${p.date}] ${p.title}`);
                    out.push(`    -> cat /blog/${p.id}.md | open /blog/${p.id}`);
                });
                return out.join('\n');
            },
        },
        ctfs: {
            desc: 'Show CTF competition results',
            fn: () => fs['/ctfs/results.txt'].content,
        },
        neofetch: {
            desc: 'Display system information',
            fn: () => {
                return [
                    '   ██╗██████╗ ██╗  ██╗       hacker@idktheflag.sh',
                    '   ██║██╔══██╗██║ ██╔╝       -------------------',
                    '   ██║██║  ██║█████╔╝        OS: idktheflagOS 1.0',
                    '   ██║██║  ██║██╔═██╗        Shell: hackershell',
                    '   ██║██████╔╝██║  ██╗       Team: idktheflag',
                    '   ╚═╝╚═════╝ ╚═╝  ╚═╝       Rating: #576 (41.885 pts)',
                    '                              Country: US #44',
                    `                              Members: ${teamData.length}`,
                    `                              Posts: ${blogData.length}`,
                    '                              Motto: "i forgor what the flag is"',
                ].join('\n');
            },
        },
        exit: {
            desc: 'Close the terminal',
            fn: () => { toggleTerminal(false); return ''; },
        },
    };

    function resolvePath(input) {
        if (!input) return cwd;
        let parts;
        if (input.startsWith('/')) {
            parts = input.split('/').filter(Boolean);
        } else {
            parts = cwd.split('/').filter(Boolean).concat(input.split('/').filter(Boolean));
        }
        const resolved = [];
        for (const p of parts) {
            if (p === '.') continue;
            if (p === '..') { resolved.pop(); continue; }
            resolved.push(p);
        }
        return '/' + resolved.join('/') || '/';
    }

    function updatePrompt() {
        const display = cwd === '/' ? '~' : '~' + cwd;
        document.getElementById('terminal-prompt').innerHTML = `hacker@idktheflag:${display}$&nbsp;`;
        const titleText = document.querySelector('.terminal-title-text');
        if (titleText) titleText.textContent = `hacker@idktheflag:${display}`;
    }

    function writeLine(text) {
        const output = document.getElementById('terminal-output');
        if (text) {
            const div = document.createElement('div');
            div.className = 'terminal-line';
            div.textContent = text;
            output.appendChild(div);
        }
    }

    function writeHTML(html) {
        const output = document.getElementById('terminal-output');
        const div = document.createElement('div');
        div.className = 'terminal-line';
        div.innerHTML = html;
        output.appendChild(div);
    }

    function executeCommand(input) {
        const output = document.getElementById('terminal-output');
        const display = cwd === '/' ? '~' : '~' + cwd;

        // Echo the command
        const cmdLine = document.createElement('div');
        cmdLine.className = 'terminal-line terminal-cmd';
        cmdLine.innerHTML = `<span class="prompt-echo">hacker@idktheflag:${display}$</span> ${escapeHtml(input)}`;
        output.appendChild(cmdLine);

        const trimmed = input.trim();
        if (!trimmed) return;

        const parts = trimmed.split(/\s+/);
        const cmd = parts[0].toLowerCase();
        const args = parts.slice(1);

        if (commands[cmd]) {
            const result = commands[cmd].fn(args);
            if (result) {
                result.split('\n').forEach(line => writeLine(line));
            }
        } else {
            writeLine(`${cmd}: command not found. Type "help" for available commands.`);
        }
    }

    function escapeHtml(s) {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function getCompletions(partial) {
        const parts = partial.split(/\s+/);
        if (parts.length <= 1) {
            // Command completion
            return Object.keys(commands).filter(c => c.startsWith(parts[0]));
        }
        // Path completion
        const pathPart = parts[parts.length - 1] || '';
        let dir, prefix;
        const lastSlash = pathPart.lastIndexOf('/');
        if (lastSlash >= 0) {
            dir = resolvePath(pathPart.substring(0, lastSlash + 1));
            prefix = pathPart.substring(lastSlash + 1);
        } else {
            dir = cwd;
            prefix = pathPart;
        }
        const node = fs[dir];
        if (!node || node.type !== 'dir') return [];
        return node.children.filter(c => c.startsWith(prefix)).map(c => {
            const cmdPart = parts.slice(0, -1).join(' ');
            const pathPrefix = lastSlash >= 0 ? pathPart.substring(0, lastSlash + 1) : '';
            return cmdPart + ' ' + pathPrefix + c;
        });
    }

    function toggleTerminal(show) {
        const overlay = document.getElementById('terminal-overlay');
        if (show === undefined) show = overlay.classList.contains('terminal-hidden');
        if (show) {
            overlay.classList.remove('terminal-hidden');
            document.getElementById('terminal-input').focus();
        } else {
            overlay.classList.add('terminal-hidden');
        }
    }

    // Event listeners
    document.addEventListener('DOMContentLoaded', () => {
        const input = document.getElementById('terminal-input');
        const body = document.getElementById('terminal-body');

        // Welcome message
        const welcomeLines = [
            'Welcome to idktheflag terminal v1.0',
            'Type "help" to see available commands.',
            '',
        ];
        welcomeLines.forEach(writeLine);

        input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                const val = input.value;
                if (val.trim()) {
                    history.unshift(val);
                    if (history.length > 50) history.pop();
                }
                historyIndex = -1;
                executeCommand(val);
                input.value = '';
                body.scrollTop = body.scrollHeight;
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                if (historyIndex < history.length - 1) {
                    historyIndex++;
                    input.value = history[historyIndex];
                }
            } else if (e.key === 'ArrowDown') {
                e.preventDefault();
                if (historyIndex > 0) {
                    historyIndex--;
                    input.value = history[historyIndex];
                } else {
                    historyIndex = -1;
                    input.value = '';
                }
            } else if (e.key === 'Tab') {
                e.preventDefault();
                const completions = getCompletions(input.value);
                if (completions.length === 1) {
                    input.value = completions[0];
                } else if (completions.length > 1) {
                    const display = cwd === '/' ? '~' : '~' + cwd;
                    const cmdLine = document.createElement('div');
                    cmdLine.className = 'terminal-line terminal-cmd';
                    cmdLine.innerHTML = `<span class="prompt-echo">hacker@idktheflag:${display}$</span> ${escapeHtml(input.value)}`;
                    document.getElementById('terminal-output').appendChild(cmdLine);
                    writeLine(completions.map(c => c.split(/\s+/).pop()).join('  '));
                }
            } else if (e.key === 'c' && e.ctrlKey) {
                e.preventDefault();
                const display = cwd === '/' ? '~' : '~' + cwd;
                const cmdLine = document.createElement('div');
                cmdLine.className = 'terminal-line terminal-cmd';
                cmdLine.innerHTML = `<span class="prompt-echo">hacker@idktheflag:${display}$</span> ${escapeHtml(input.value)}^C`;
                document.getElementById('terminal-output').appendChild(cmdLine);
                input.value = '';
            }
        });

        // Click anywhere in terminal body focuses input
        body.addEventListener('click', () => input.focus());

        // Toggle button
        document.getElementById('terminal-toggle').addEventListener('click', () => toggleTerminal());
        document.getElementById('terminal-close').addEventListener('click', () => toggleTerminal(false));

        // Keyboard shortcut: Ctrl+`
        document.addEventListener('keydown', (e) => {
            if (e.key === '`' && e.ctrlKey) {
                e.preventDefault();
                toggleTerminal();
            }
            if (e.key === 'Escape' && !document.getElementById('terminal-overlay').classList.contains('terminal-hidden')) {
                toggleTerminal(false);
            }
        });
    });
})();
</script>

<style is:global>
    #terminal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.7);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(3px);
        transition: opacity 0.15s ease;
    }

    #terminal-overlay.terminal-hidden {
        display: none;
    }

    #terminal-window {
        width: 90%;
        max-width: 820px;
        height: 70vh;
        max-height: 600px;
        background: #0a0a0a;
        border: 1px solid #333;
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
        overflow: hidden;
    }

    #terminal-titlebar {
        display: flex;
        align-items: center;
        padding: 0 12px;
        height: 36px;
        background: #1a1a1a;
        border-bottom: 1px solid #333;
        flex-shrink: 0;
        user-select: none;
    }

    .terminal-title-dots {
        display: flex;
        gap: 6px;
        margin-right: 12px;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .dot-red { background: #ff5f57; }
    .dot-yellow { background: #febc2e; }
    .dot-green { background: #28c840; }

    .terminal-title-text {
        flex: 1;
        text-align: center;
        font-family: "Courier New", monospace;
        font-size: 0.8em;
        color: #888;
    }

    #terminal-close {
        background: none;
        border: none;
        color: #666;
        font-size: 1.4em;
        cursor: pointer;
        padding: 0 4px;
        line-height: 1;
    }

    #terminal-close:hover {
        color: #fff;
    }

    #terminal-body {
        flex: 1;
        padding: 12px;
        overflow-y: auto;
        font-family: "Courier New", "Fira Code", monospace;
        font-size: 14px;
        line-height: 1.5;
        color: #c8c8c8;
    }

    #terminal-body::-webkit-scrollbar {
        width: 6px;
    }

    #terminal-body::-webkit-scrollbar-track {
        background: transparent;
    }

    #terminal-body::-webkit-scrollbar-thumb {
        background: #333;
        border-radius: 3px;
    }

    .terminal-line {
        white-space: pre-wrap;
        word-break: break-all;
        min-height: 1.5em;
    }

    .terminal-cmd {
        color: #e8e8e8;
    }

    .prompt-echo {
        color: #28c840;
        margin-right: 0.5em;
    }

    #terminal-input-line {
        display: flex;
        align-items: center;
        margin-top: 2px;
    }

    #terminal-prompt {
        color: #28c840;
        white-space: nowrap;
        font-family: "Courier New", "Fira Code", monospace;
        font-size: 14px;
    }

    #terminal-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: #e8e8e8;
        font-family: "Courier New", "Fira Code", monospace;
        font-size: 14px;
        caret-color: #28c840;
        padding: 0;
        margin: 0;
    }

    #terminal-input::selection {
        background: #264f78;
    }
</style>
