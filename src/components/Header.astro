---
---
<header>
    <nav>
        <h2>
            <a href="/" class="brand-link">
                <img src="/idktheflag-blank.png" alt="idktheflag logo" class="nav-logo" />
                idktheflag
            </a>
        </h2>
        <div class="internal-links">
            <a href="/">Home</a>
            <a href="/blog">Blog</a>
            <a href="/ctfs">CTFs</a>
			<a href="https://docs.idktheflag.sh">Docs</a>
            <a href="/about">About</a>
            <a href="/team">Bios</a>
        </div>
        <div class="social-links">
            <button id="terminal-toggle" title="Terminal Mode (Ctrl+`)" aria-label="Toggle Terminal">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="4 17 10 11 4 5"></polyline>
                    <line x1="12" y1="19" x2="20" y2="19"></line>
                </svg>
            </button>
            <a href="https://x.com/idktheflag" target="_blank" title="X / Twitter">
                <span class="sr-only">X / Twitter</span>
                <svg viewBox="0 0 24 24" aria-hidden="true" width="28" height="28" fill="currentColor">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
                </svg>
            </a>
            <a href="https://github.com/idktheflag" target="_blank" title="GitHub">
                <span class="sr-only">GitHub</span>
                <svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28">
                    <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
                </svg>
            </a>
        </div>
        <button id="hamburger" class="hamburger" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </nav>
    <div id="mobile-menu" class="mobile-menu">
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
        <a href="/ctfs">CTFs</a>
        <a href="https://docs.idktheflag.sh">Docs</a>
        <a href="/about">About</a>
        <a href="/team">Bios</a>
        <div class="mobile-menu-bottom">
            <button id="terminal-toggle-mobile" aria-label="Toggle Terminal">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="4 17 10 11 4 5"></polyline>
                    <line x1="12" y1="19" x2="20" y2="19"></line>
                </svg>
                Terminal
            </button>
            <a href="https://x.com/idktheflag" target="_blank">Twitter</a>
            <a href="https://github.com/idktheflag" target="_blank">GitHub</a>
        </div>
    </div>
</header>

<script>
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobile-menu');

    hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('open');
        mobileMenu.classList.toggle('open');
    });

    // Close menu on link click
    mobileMenu.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
            hamburger.classList.remove('open');
            mobileMenu.classList.remove('open');
        });
    });

    // Mobile terminal toggle
    const termToggleMobile = document.getElementById('terminal-toggle-mobile');
    if (termToggleMobile) {
        termToggleMobile.addEventListener('click', () => {
            hamburger.classList.remove('open');
            mobileMenu.classList.remove('open');
            document.getElementById('terminal-overlay')?.classList.remove('terminal-hidden');
            document.getElementById('terminal-input')?.focus();
        });
    }
</script>

<style>
    header {
        margin: 0;
        padding: 0 1.5em;
        background: var(--bg-color);
        border-bottom: 2px solid var(--accent);
        position: relative;
    }

    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 60px;
        max-width: 1200px;
        margin: 0 auto;
    }

    h2 {
        margin: 0;
        font-size: 1.2em;
        flex: 1;
        display: flex;
        justify-content: flex-start;
    }

    .internal-links {
        display: flex;
        gap: 1.5em;
        justify-content: center;
    }

    nav a {
        color: var(--text-heading);
        font-weight: 700;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    nav a:hover {
        color: var(--accent);
    }

    .brand-link {
        display: flex;
        align-items: center;
        gap: 0.5em;
    }

    .nav-logo {
        height: 1.5em;
        width: auto;
        image-rendering: pixelated;
    }

    .social-links {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 0.8em;
        justify-content: flex-end;
    }

    #terminal-toggle {
        background: none;
        border: 1px solid #30363d;
        color: var(--text-heading);
        cursor: pointer;
        padding: 0.3em 0.5em;
        border-radius: 4px;
        display: flex;
        align-items: center;
        transition: border-color 0.2s ease, color 0.2s ease;
    }

    #terminal-toggle:hover {
        border-color: var(--accent);
        color: var(--accent);
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
    }

    /* Hamburger button */
    .hamburger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.4em;
        z-index: 1001;
    }

    .hamburger span {
        display: block;
        width: 22px;
        height: 2px;
        background: var(--text-heading);
        transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .hamburger.open span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }

    .hamburger.open span:nth-child(2) {
        opacity: 0;
    }

    .hamburger.open span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    /* Mobile menu */
    .mobile-menu {
        display: none;
        flex-direction: column;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--bg-color);
        border-bottom: 2px solid var(--accent);
        padding: 1rem 1.5rem;
        z-index: 1000;
    }

    .mobile-menu a {
        color: var(--text-heading);
        font-weight: 700;
        text-decoration: none;
        padding: 0.7rem 0;
        border-bottom: 1px solid #21262d;
        transition: color 0.2s ease;
    }

    .mobile-menu a:hover {
        color: var(--accent);
    }

    .mobile-menu-bottom {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding-top: 0.8rem;
        margin-top: 0.3rem;
    }

    .mobile-menu-bottom button {
        background: none;
        border: 1px solid #30363d;
        color: var(--text-heading);
        cursor: pointer;
        padding: 0.4em 0.7em;
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: 0.4em;
        font-family: inherit;
        font-size: 0.9em;
        font-weight: 700;
    }

    .mobile-menu-bottom a {
        border-bottom: none;
        padding: 0;
    }

    @media (max-width: 720px) {
        .internal-links { display: none; }
        .social-links { display: none; }
        .hamburger { display: flex; }
        .mobile-menu.open { display: flex; }
    }
</style>
